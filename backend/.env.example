DATABASE_URL=postgresql+asyncpg://kubewise:kubewise@localhost:5432/kubewise
DATABASE_URL_SYNC=postgresql://kubewise:kubewise@localhost:5432/kubewise
PROMETHEUS_URL=http://localhost:9090
# If MOCK_MODE=false and Prometheus is down, still serve mock metrics (recommended for Render demos).
PROMETHEUS_FALLBACK_MOCK=true
MOCK_MODE=true
# Origins of the browser app (Next.js / Vercel), NOT the API URL. Example: https://kubewise.vercel.app
CORS_ORIGINS=["http://localhost:3000","https://your-app.vercel.app"]
ENABLE_METRICS_SCHEDULER=false
METRICS_COLLECTION_INTERVAL_MINUTES=15
METRICS_COLLECTION_SCENARIO=wasteful
ENABLE_DB_PERSISTENCE=true
