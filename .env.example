# Copy to .env in this folder for docker compose variable substitution (optional)

# Mock data (default for local demo)
MOCK_MODE=true

# When MOCK_MODE=false, point at your Prometheus (docker service name or host)
PROMETHEUS_URL=http://prometheus:9090

# Scheduled metrics refresh inside the API process
ENABLE_METRICS_SCHEDULER=false
METRICS_COLLECTION_INTERVAL_MINUTES=15
METRICS_COLLECTION_SCENARIO=wasteful

# Persist snapshots, recommendations, and simulation rows to Postgres (requires DB)
ENABLE_DB_PERSISTENCE=true
